# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017/clinic-management

# ─────────────────────────────────────────────
# JWT & Cookies
# ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
TOKEN_EXPIRE_TIME=24h
COOKIE_SECRET=your_cookie_secret_here

# ─────────────────────────────────────────────
# Cloudinary  (image uploads)
# Dashboard → https://cloudinary.com/console
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─────────────────────────────────────────────
# Google Gemini AI
# Get your key → https://aistudio.google.com/app/apikey
# Used for: AI Diagnosis Assistant & prescription explanation
# If left blank, the app falls back to general clinical guidance
#   (no crash, no 503 – graceful degradation is built in)
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
